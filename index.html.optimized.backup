<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <!-- 安全头部 -->
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https: wss:;" />
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    
    <!-- SEO元数据 -->
    <meta name="description" content="贾维斯智能体 - 基于AI的智能助手，提供智能对话、任务管理和自动化功能" />
    <meta name="keywords" content="贾维斯, AI助手, 智能对话, 任务管理, 自动化" />
    <meta name="author" content="JarvisAgent" />
    <meta name="robots" content="index, follow" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    
    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="贾维斯智能体" />
    <meta property="og:description" content="基于AI的智能助手，提供智能对话、任务管理和自动化功能" />
    <meta property="og:locale" content="zh_CN" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="贾维斯智能体" />
    <meta name="twitter:description" content="基于AI的智能助手" />
    
    <!-- 预加载关键资源 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- 图标 -->
    <link rel="icon" type="image/svg+xml" href="/vite.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    
    <!-- 主题颜色 -->
    <meta name="theme-color" content="#1a1a2e" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    
    <!-- 性能优化 -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    
    <!-- 样式 -->
    <style>
        /* CSS变量定义 - 现代主题系统 */
        :root {
            /* 颜色变量 - 浅色模式 */
            --color-primary: #4a6fa5;
            --color-primary-dark: #3a5a8a;
            --color-secondary: #6b8cae;
            --color-background: #ffffff;
            --color-surface: #f8f9fa;
            --color-text: #212529;
            --color-text-secondary: #6c757d;
            --color-border: #dee2e6;
            --color-success: #28a745;
            --color-warning: #ffc107;
            --color-error: #dc3545;
            --color-info: #17a2b8;
            
            /* 间距变量 */
            --spacing-xs: 0.25rem;
            --spacing-sm: 0.5rem;
            --spacing-md: 1rem;
            --spacing-lg: 1.5rem;
            --spacing-xl: 2rem;
            
            /* 字体变量 */
            --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            --font-size-xs: 0.75rem;
            --font-size-sm: 0.875rem;
            --font-size-md: 1rem;
            --font-size-lg: 1.125rem;
            --font-size-xl: 1.25rem;
            --font-size-2xl: 1.5rem;
            
            /* 边框半径 */
            --border-radius-sm: 0.25rem;
            --border-radius-md: 0.5rem;
            --border-radius-lg: 1rem;
            
            /* 阴影 */
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 6px rgba(0,0,0,0.1);
            --shadow-lg: 0 10px 15px rgba(0,0,0,0.1);
            
            /* 过渡动画 */
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            
            /* 布局变量 */
            --header-height: 35px;
            --sidebar-width: 250px;
            --terminal-height: 150px;
        }
        
        /* 暗色模式变量 */
        @media (prefers-color-scheme: dark) {
            :root {
                --color-primary: #5d7ab5;
                --color-primary-dark: #4a6396;
                --color-secondary: #7a9bb8;
                --color-background: #1a1a2e;
                --color-surface: #252541;
                --color-text: #e9ecef;
                --color-text-secondary: #adb5bd;
                --color-border: #495057;
                --color-success: #34c759;
                --color-warning: #ffcc00;
                --color-error: #ff453a;
                --color-info: #0a84ff;
            }
        }
        
        /* 强制暗色模式类 */
        .dark-mode {
            --color-primary: #5d7ab5;
            --color-primary-dark: #4a6396;
            --color-secondary: #7a9bb8;
            --color-background: #1a1a2e;
            --color-surface: #252541;
            --color-text: #e9ecef;
            --color-text-secondary: #adb5bd;
            --color-border: #495057;
            --color-success: #34c759;
            --color-warning: #ffcc00;
            --color-error: #ff453a;
            --color-info: #0a84ff;
        }
        
        /* 基础样式 - 优化选择器 */
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        html {
            font-size: 16px;
            scroll-behavior: smooth;
        }
        
        body {
            font-family: var(--font-family);
            font-size: var(--font-size-md);
            line-height: 1.6;
            color: var(--color-text);
            background-color: var(--color-background);
            transition: background-color var(--transition-normal), color var(--transition-normal);
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        /* 加载状态 */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: var(--color-background);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            transition: opacity var(--transition-normal);
        }
        
        .loading-overlay.hidden {
            opacity: 0;
            pointer-events: none;
        }
        
        .loading-spinner {
            width: 50px;
            height: 50px;
            border: 3px solid var(--color-border);
            border-top-color: var(--color-primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        
        .loading-text {
            margin-top: var(--spacing-md);
            color: var(--color-text-secondary);
            font-size: var(--font-size-sm);
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Toast提示系统 */
        .toast-container {
            position: fixed;
            top: var(--spacing-md);
            right: var(--spacing-md);
            z-index: 10000;
            display: flex;
            flex-direction: column;
            gap: var(--spacing-sm);
        }
        
        .toast {
            padding: var(--spacing-md);
            border-radius: var(--border-radius-md);
            box-shadow: var(--shadow-lg);
            animation: slideIn 0.3s ease;
            max-width: 400px;
            display: flex;
            align-items: center;
            gap: var(--spacing-sm);
        }
        
        .toast.success { background-color: var(--color-success); color: white; }
        .toast.error { background-color: var(--color-error); color: white; }
        .toast.warning { background-color: var(--color-warning); color: #333; }
        .toast.info { background-color: var(--color-info); color: white; }
        
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        
        /* 错误提示 */
        .error-container {
            position: fixed;
            top: var(--spacing-md);
            right: var(--spacing-md);
            background-color: var(--color-error);
            color: white;
            padding: var(--spacing-md);
            border-radius: var(--border-radius-md);
            box-shadow: var(--shadow-lg);
            z-index: 10000;
            max-width: 400px;
            animation: slideIn 0.3s ease;
        }
        
        /* 无障碍焦点样式 */
        :focus-visible {
            outline: 2px solid var(--color-primary);
            outline-offset: 2px;
        }
        
        /* 跳过导航链接 - 无障碍 */
        .skip-link {
            position: absolute;
            top: -40px;
            left: 0;
            background: var(--color-primary);
            color: white;
            padding: var(--spacing-sm) var(--spacing-md);
            z-index: 100;
            transition: top var(--transition-fast);
        }
        
        .skip-link:focus {
            top: 0;
        }
        
        /* 应用容器 */
        #app {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        
        /* 汉堡菜单按钮 */
        .hamburger-menu {
            display: none;
            position: fixed;
            top: var(--spacing-md);
            left: var(--spacing-md);
            z-index: 1000;
            background: var(--color-primary);
            border: none;
            border-radius: var(--border-radius-sm);
            padding: var(--spacing-sm);
            cursor: pointer;
            transition: all var(--transition-fast);
        }
        
        .hamburger-menu:hover {
            background: var(--color-primary-dark);
        }
        
        .hamburger-menu span {
            display: block;
            width: 20px;
            height: 2px;
            background: white;
            margin: 4px 0;
            transition: all var(--transition-fast);
        }
        
        /* 暗黑模式切换按钮 */
        .dark-mode-toggle {
            position: fixed;
            top: var(--spacing-md);
            right: var(--spacing-md);
            z-index: 1000;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--border-radius-sm);
            padding: var(--spacing-sm);
            cursor: pointer;
            transition: all var(--transition-fast);
        }
        
        .dark-mode-toggle:hover {
            background: var(--color-primary);
            color: white;
        }
        
        /* 响应式设计 */
        @media (max-width: 768px) {
            html {
                font-size: 14px;
            }
            
            .hamburger-menu {
                display: block;
            }
            
            .dark-mode-toggle {
                right: 60px;
            }
            
            .error-container {
                left: var(--spacing-md);
                right: var(--spacing-md);
                max-width: none;
            }
            
            .toast-container {
                left: var(--spacing-md);
                right: var(--spacing-md);
                max-width: none;
            }
        }
        
        /* 打印样式 */
        @media print {
            .loading-overlay,
            .error-container,
            .skip-link,
            .hamburger-menu,
            .dark-mode-toggle,
            .toast-container {
                display: none !important;
            }
        }
        
        /* 动画效果 */
        .fade-in {
            animation: fadeIn 0.5s ease;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        
        .slide-up {
            animation: slideUp 0.3s ease;
        }
        
        @keyframes slideUp {
            from {
                transform: translateY(20px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
        
        /* Intersection Observer动画类 */
        .observe-animate {
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.5s ease;
        }
        
        .observe-animate.visible {
            opacity: 1;
            transform: translateY(0);
        }
        
        /* 触摸滑动支持 */
        .touch-swipe {
            touch-action: pan-y;
            -webkit-overflow-scrolling: touch;
        }
        
        /* CSS Grid布局优化 */
        .grid-container {
            display: grid;
            grid-template-columns: 1fr;
            grid-template-rows: auto 1fr auto;
            min-height: 100vh;
        }
        
        @media (min-width: 768px) {
            .grid-container {
                grid-template-columns: var(--sidebar-width) 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- 跳过导航链接 - 无障碍 -->
    <a href="#app" class="skip-link">跳转到主要内容</a>
    
    <!-- 汉堡菜单按钮（移动端） -->
    <button class="hamburger-menu" id="hamburgerMenu" aria-label="打开菜单" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
    </button>
    
    <!-- 暗黑模式切换按钮 -->
    <button class="dark-mode-toggle" id="darkModeToggle" aria-label="切换暗黑模式">
        <span id="darkModeIcon">🌙</span>
    </button>
    
    <!-- Toast提示容器 -->
    <div class="toast-container" id="toastContainer" role="status" aria-live="polite"></div>
    
    <!-- 加载状态 -->
    <div class="loading-overlay" id="loadingOverlay" role="status" aria-live="polite">
        <div class="loading-spinner" aria-hidden="true"></div>
        <p class="loading-text">正在加载贾维斯智能体...</p>
    </div>
    
    <!-- 错误提示容器 -->
    <div id="errorContainer" class="error-container" style="display: none;" role="alert" aria-live="assertive"></div>
    
    <!-- 主应用容器 -->
    <div id="app" role="main" aria-label="贾维斯智能体主界面"></div>
    
    <!-- 脚本 -->
    <script type="module" src="/src/main.ts"></script>
    
    <!-- 性能监控和错误处理 -->
    <script>
        // 安全工具函数
        const SecurityUtils = {
            // HTML转义函数
            escapeHtml: function(text) {
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            },
            
            // 安全的DOM操作
            safeSetHtml: function(element, html) {
                if (element) {
                    element.innerHTML = html;
                }
            },
            
            // 输入验证
            validateInput: function(input, maxLength = 1000) {
                if (!input || typeof input !== 'string') {
                    return { valid: false, error: '输入必须是字符串' };
                }
                if (input.length > maxLength) {
                    return { valid: false, error: `输入长度不能超过${maxLength}字符` };
                }
                return { valid: true };
            },
            
            // 防XSS的文本内容设置
            safeSetText: function(element, text) {
                if (element) {
                    element.textContent = text;
                }
            }
        };
        
        // Toast提示系统
        const ToastSystem = {
            container: null,
            
            init: function() {
                this.container = document.getElementById('toastContainer');
            },
            
            show: function(message, type = 'info', duration = 3000) {
                if (!this.container) this.init();
                
                const toast = document.createElement('div');
                toast.className = `toast ${type}`;
                toast.setAttribute('role', 'alert');
                
                const icon = this.getIcon(type);
                toast.innerHTML = `${icon} ${SecurityUtils.escapeHtml(message)}`;
                
                this.container.appendChild(toast);
                
                // 自动移除
                setTimeout(() => {
                    toast.style.animation = 'slideIn 0.3s ease reverse';
                    setTimeout(() => {
                        if (toast.parentNode) {
                            toast.parentNode.removeChild(toast);
                        }
                    }, 300);
                }, duration);
            },
            
            getIcon: function(type) {
                const icons = {
                    success: '✓',
                    error: '✗',
                    warning: '⚠',
                    info: 'ℹ'
                };
                return icons[type] || icons.info;
            },
            
            success: function(message) {
                this.show(message, 'success');
            },
            
            error: function(message) {
                this.show(message, 'error');
            },
            
            warning: function(message) {
                this.show(message, 'warning');
            },
            
            info: function(message) {
                this.show(message, 'info');
            }
        };
        
        // 错误处理
        window.addEventListener('error', function(event) {
            console.error('全局错误:', event.error);
            showError('发生错误: ' + event.error.message);
        });
        
        window.addEventListener('unhandledrejection', function(event) {
            console.error('未处理的Promise拒绝:', event.reason);
            showError('操作失败: ' + event.reason);
        });
        
        // 显示错误信息
        function showError(message) {
            const errorContainer = document.getElementById('errorContainer');
            if (errorContainer) {
                SecurityUtils.safeSetText(errorContainer, message);
                errorContainer.style.display = 'block';
                
                // 5秒后自动隐藏
                setTimeout(() => {
                    errorContainer.style.display = 'none';
                }, 5000);
            }
        }
        
        // 隐藏加载状态
        function hideLoading() {
            const loadingOverlay = document.getElementById('loadingOverlay');
            if (loadingOverlay) {
                loadingOverlay.classList.add('hidden');
                setTimeout(() => {
                    loadingOverlay.style.display = 'none';
                }, 300);
            }
        }
        
        // 暗黑模式切换
        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            const isDark = document.body.classList.contains('dark-mode');
            localStorage.setItem('darkMode', isDark);
            
            // 更新图标
            const icon = document.getElementById('darkModeIcon');
            if (icon) {
                icon.textContent = isDark ? '☀️' : '🌙';
            }
            
            // 显示Toast提示
            ToastSystem.info(isDark ? '已切换到暗黑模式' : '已切换到浅色模式');
        }
        
        // 汉堡菜单切换
        function toggleHamburgerMenu() {
            const menu = document.getElementById('hamburgerMenu');
            const isExpanded = menu.getAttribute('aria-expanded') === 'true';
            menu.setAttribute('aria-expanded', !isExpanded);
            
            // 这里可以添加移动端菜单的显示/隐藏逻辑
            ToastSystem.info(isExpanded ? '关闭菜单' : '打开菜单');
        }
        
        // Intersection Observer动画
        function initIntersectionObserver() {
            if ('IntersectionObserver' in window) {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('visible');
                        }
                    });
                }, {
                    threshold: 0.1,
                    rootMargin: '50px'
                });
                
                // 观察所有需要动画的元素
                document.querySelectorAll('.observe-animate').forEach(el => {
                    observer.observe(el);
                });
            }
        }
        
        // 触摸滑动支持
        function initTouchSupport() {
            // 为响应式元素添加触摸支持
            const touchElements = document.querySelectorAll('.touch-swipe');
            touchElements.forEach(el => {
                let startX = 0;
                let startY = 0;
                
                el.addEventListener('touchstart', (e) => {
                    startX = e.touches[0].clientX;
                    startY = e.touches[0].clientY;
                });
                
                el.addEventListener('touchend', (e) => {
                    const endX = e.changedTouches[0].clientX;
                    const endY = e.changedTouches[0].clientY;
                    const diffX = startX - endX;
                    const diffY = startY - endY;
                    
                    // 水平滑动检测
                    if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 50) {
                        if (diffX > 0) {
                            // 向左滑动
                            console.log('向左滑动');
                        } else {
                            // 向右滑动
                            console.log('向右滑动');
                        }
                    }
                });
            });
        }
        
        // 监听应用加载完成
        document.addEventListener('DOMContentLoaded', function() {
            // 初始化Toast系统
            ToastSystem.init();
            
            // 初始化暗色模式
            const savedDarkMode = localStorage.getItem('darkMode');
            if (savedDarkMode === 'true') {
                document.body.classList.add('dark-mode');
                const icon = document.getElementById('darkModeIcon');
                if (icon) icon.textContent = '☀️';
            }
            
            // 绑定事件
            document.getElementById('darkModeToggle')?.addEventListener('click', toggleDarkMode);
            document.getElementById('hamburgerMenu')?.addEventListener('click', toggleHamburgerMenu);
            
            // 初始化动画观察器
            initIntersectionObserver();
            
            // 初始化触摸支持
            initTouchSupport();
            
            // 模拟应用加载完成（实际项目中应由Vue应用触发）
            setTimeout(hideLoading, 1000);
            
            // 显示欢迎Toast
            setTimeout(() => {
                ToastSystem.success('贾维斯智能体已加载完成！');
            }, 1500);
        });
        
        // 性能监控
        if ('PerformanceObserver' in window) {
            const perfObserver = new PerformanceObserver((list) => {
                for (const entry of list.getEntries()) {
                    console.log('性能指标:', entry.name, entry.duration);
                }
            });
            perfObserver.observe({ entryTypes: ['measure', 'navigation'] });
        }
        
        // 导出安全工具函数供其他模块使用
        window.SecurityUtils = SecurityUtils;
        window.ToastSystem = ToastSystem;
    </script>
    
    <!-- 无障碍声明 -->
    <noscript>
        <div style="padding: 20px; text-align: center; background: #f8d7da; color: #721c24;">
            <p>此应用需要JavaScript才能正常运行。请启用JavaScript后重新加载页面。</p>
        </div>
    </noscript>
</body>
</html>